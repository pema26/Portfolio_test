---
// ============================================================================
//  SEO.astro  —  everything that goes in the <head> for search + social
// ============================================================================
//
//  PURPOSE: produces the page <title>, description, canonical link, and the
//  Open Graph / Twitter "card" tags so that when a link to your site is shared
//  on LinkedIn / X / Slack it shows a nice title, description, and image.
//
//  You don't normally edit this file. Each page passes in its own title and
//  description (see how layouts/BaseLayout.astro calls it).
// ============================================================================

interface Props {
  title: string;
  description: string;
  /** Optional path to a custom social-share image (defaults to og-image.png). */
  image?: string;
}

const { title, description, image = '/og-image.png' } = Astro.props;

// Build absolute URLs (needed by Open Graph) from the `site` value set in
// astro.config.mjs. Astro.url is the current page's address.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!-- Character set + responsive viewport (required for mobile) -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary SEO tags -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph (Facebook / LinkedIn / Slack) -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImageURL} />

<!-- Favicon (replace public/favicon.svg with your own if you like) -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Web fonts (Inter for UI, Lora for headings). font-display:swap keeps the
     page readable while they load. -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@500;600;700&display=swap"
/>
