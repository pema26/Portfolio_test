---
// ============================================================================
//  Footer.astro  —  the bottom bar shown on every page
// ============================================================================
//
//  PURPOSE: copyright line and a few quick social links.
//  EDIT HERE: replace the [[...]] placeholders with your real URLs (or do it
//  globally — see the README's placeholder list).
// ============================================================================

const year = new Date().getFullYear();

// EDIT HERE: your social / scholarly links.
const socials = [
  { href: '[[GITHUB_URL]]', label: 'GitHub' },
  { href: '[[LINKEDIN_URL]]', label: 'LinkedIn' },
  { href: '[[ORCID_URL]]', label: 'ORCID' },
  { href: '[[SCHOLAR_URL]]', label: 'Google Scholar' },
];
---

<footer class="border-t border-slate-200 dark:border-slate-800">
  <div class="flex w-full flex-col items-center justify-between gap-3 px-4 py-6 text-sm text-slate-500 sm:flex-row sm:px-6 lg:px-10 dark:text-slate-400">
    <p>&copy; {year} [[YOUR_NAME]]. Built with Astro.</p>
    <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
      {
        socials.map((social) => (
          <li>
            <a
              href={social.href}
              class="transition hover:text-accent-500"
              target="_blank"
              rel="me noopener noreferrer"
            >
              {social.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
