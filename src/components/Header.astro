---
// ============================================================================
//  Header.astro  —  the top navigation bar shown on every page
// ============================================================================
//
//  PURPOSE: your name/logo on the left, the navigation links and the dark-mode
//  toggle on the right.
//
//  HOW TO ADD A NAV LINK: copy one line in the `links` array below and change
//  its href + label. Each href matches a file in src/pages/ (file-based
//  routing), so "/about" -> src/pages/about.astro.
// ============================================================================
import ThemeToggle from './ThemeToggle.astro';

// EDIT HERE: the navigation menu. Add/remove items by editing this list.
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/problems', label: 'Problems' },
  { href: '/research', label: 'Research' },
  { href: '/notes', label: 'Notes' },
  { href: '/contact', label: 'Contact' },
];

// Work out which link is the current page so we can highlight it.
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80">
  <nav class="flex w-full items-center justify-between px-4 py-3 sm:px-6 lg:px-10" aria-label="Main navigation">
    <!-- Name / wordmark links back home. EDIT HERE to change the wordmark. -->
    <a href="/" class="font-serif text-lg font-semibold tracking-tight text-slate-900 dark:text-white">
      [[YOUR_NAME]]
    </a>

    <div class="flex items-center gap-1">
      <ul class="hidden items-center gap-1 sm:flex">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class:list={[
                  'rounded-lg px-3 py-2 text-sm font-medium transition',
                  isActive(link.href)
                    ? 'text-accent-500'
                    : 'text-slate-600 hover:text-accent-500 dark:text-slate-300 dark:hover:text-accent-400',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ThemeToggle />
    </div>
  </nav>

  <!-- On small phones the links collapse to a simple scrollable row. -->
  <ul class="flex items-center gap-1 overflow-x-auto px-4 pb-2 sm:hidden">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'whitespace-nowrap rounded-lg px-3 py-1.5 text-sm font-medium transition',
              isActive(link.href)
                ? 'text-accent-500'
                : 'text-slate-600 hover:text-accent-500 dark:text-slate-300',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</header>
