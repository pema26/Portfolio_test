---
// ============================================================================
//  src/pages/notes/[...slug].astro  —  ONE note's page
// ============================================================================
//
//  Same pattern as projects/[...slug].astro: this one file generates a page
//  for every note Markdown file automatically. Edit the Markdown to change a
//  note; you don't edit this template.
// ============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const dateLabel = note.data.date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${note.data.title} — [[YOUR_NAME]]`} description={note.data.description}>
  <a href="/notes" class="text-sm font-medium text-accent-500 hover:underline">
    &larr; All notes
  </a>

  <header class="mt-4">
    <time class="text-sm text-slate-500 dark:text-slate-400">{dateLabel}</time>
    <h1 class="mt-2 font-serif text-3xl font-bold text-slate-900 dark:text-white">
      {note.data.title}
    </h1>
  </header>

  <article class="prose-content mt-8 text-slate-700 dark:text-slate-300">
    <Content />
  </article>
</BaseLayout>
