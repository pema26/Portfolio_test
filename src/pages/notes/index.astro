---
// ============================================================================
//  src/pages/notes/index.astro  —  the NOTES / blog list  ("/notes" route)
// ============================================================================
//
//  WHAT'S HERE: lists every entry in the `notes` content collection (every
//  .md file in src/content/notes/), newest first. Add a note by dropping a new
//  Markdown file in that folder — no need to touch this file.
// ============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="Notes — [[YOUR_NAME]]"
  description="Short write-ups and notes on software, graphics, and research."
>
  <h1 class="font-serif text-3xl font-bold text-slate-900 dark:text-white">Notes</h1>
  <p class="mt-2 text-slate-600 dark:text-slate-400">
    Short write-ups on things I'm learning and building.
  </p>

  <ul class="mt-8 space-y-4">
    {
      notes.map((note) => (
        <li class="rounded-xl border border-slate-200 p-5 transition hover:border-accent-400 dark:border-slate-800 dark:hover:border-accent-500">
          <a href={`/notes/${note.id}`} class="block">
            <time class="text-sm text-slate-500 dark:text-slate-400">
              {note.data.date.toLocaleDateString('en-GB', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <h2 class="mt-1 font-serif text-xl font-semibold text-slate-900 dark:text-white">
              {note.data.title}
            </h2>
            <p class="mt-1 text-slate-600 dark:text-slate-400">{note.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
