---
// ============================================================================
//  src/pages/research/index.astro  —  the RESEARCH list  ("/research" route)
// ============================================================================
//
//  WHAT'S HERE: every entry in the `research` content collection (each .md file
//  in src/content/research/). Add a research write-up by dropping a new Markdown
//  file in that folder — you don't edit this page.
// ============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const research = (await getCollection('research')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="Research — [[YOUR_NAME]]"
  description="Scientific and research work in molecular biology, presented as short write-ups."
>
  <h1 class="font-serif text-3xl font-bold text-slate-900 dark:text-white">Research</h1>
  <p class="mt-2 text-slate-600 dark:text-slate-400">
    Scientific work from my molecular-biology background, written up as short
    case studies.
  </p>

  {
    research.length === 0 ? (
      <p class="mt-8 text-slate-500 dark:text-slate-400">No research entries yet.</p>
    ) : (
      <div class="mt-8 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
        {research.map((entry) => (
          <ProjectCard
            id={entry.id}
            title={entry.data.title}
            description={entry.data.description}
            tags={entry.data.tags}
            basePath="/research"
            badge={{ label: 'Research', tone: 'teal' }}
          />
        ))}
      </div>
    )
  }
</BaseLayout>
