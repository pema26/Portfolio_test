---
// ============================================================================
//  src/pages/404.astro  —  the custom "page not found" page
// ============================================================================
//
//  Shown automatically when a visitor hits a URL that doesn't exist. Most
//  static hosts (Cloudflare Pages, GitHub Pages) serve this file on 404.
// ============================================================================

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — [[YOUR_NAME]]" description="That page could not be found.">
  <section class="py-16 text-center">
    <p class="font-serif text-6xl font-bold text-accent-500">404</p>
    <h1 class="mt-4 font-serif text-2xl font-semibold text-slate-900 dark:text-white">
      Page not found
    </h1>
    <p class="mx-auto mt-2 max-w-md text-slate-600 dark:text-slate-400">
      Sorry, the page you were looking for doesn't exist or may have moved.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-lg bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent-500"
    >
      Back home
    </a>
  </section>
</BaseLayout>
