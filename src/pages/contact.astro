---
// ============================================================================
//  src/pages/contact.astro  —  the CONTACT page  ("/contact" route)
// ============================================================================
//
//  WHAT'S HERE: your email and the important profile links. Replace every
//  [[...]] placeholder with your real details (see the README placeholder
//  list to find them all at once).
// ============================================================================

import BaseLayout from '../layouts/BaseLayout.astro';

// EDIT HERE: your contact links. The href values are placeholders.
const links = [
  { label: 'Email', value: '[[YOUR_EMAIL]]', href: 'mailto:[[YOUR_EMAIL]]' },
  { label: 'GitHub', value: '[[GITHUB_URL]]', href: '[[GITHUB_URL]]' },
  { label: 'LinkedIn', value: '[[LINKEDIN_URL]]', href: '[[LINKEDIN_URL]]' },
  { label: 'ORCID', value: '[[ORCID_URL]]', href: '[[ORCID_URL]]' },
  { label: 'Google Scholar', value: '[[SCHOLAR_URL]]', href: '[[SCHOLAR_URL]]' },
];
---

<BaseLayout
  title="Contact — [[YOUR_NAME]]"
  description="Get in touch — email, GitHub, LinkedIn, ORCID, and Google Scholar."
>
  <h1 class="font-serif text-3xl font-bold text-slate-900 dark:text-white">Contact</h1>
  <p class="mt-2 max-w-2xl text-slate-600 dark:text-slate-400">
    The best way to reach me is by email. You can also find me on the platforms
    below.
  </p>

  <ul class="mt-8 max-w-xl divide-y divide-slate-200 dark:divide-slate-800">
    {
      links.map((link) => (
        <li class="flex items-center justify-between py-3">
          <span class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
            {link.label}
          </span>
          <a
            href={link.href}
            class="text-accent-500 transition hover:underline"
            target={link.href.startsWith('mailto:') ? undefined : '_blank'}
            rel="noopener noreferrer"
          >
            {link.value}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
