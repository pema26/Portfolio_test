---
// ============================================================================
//  src/pages/projects/index.astro  —  the PROJECTS list  ("/projects" route)
// ============================================================================
//
//  WHAT'S HERE: every entry in the `projects` content collection, grouped into
//  three labelled sections — Flagship, Guided builds, and Mini projects — based
//  on each file's `category`. You never edit this page to add a project: just
//  add a new Markdown file in src/content/projects/ with the right category and
//  it appears under the matching heading. See the README for the steps.
// ============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_META, STATUS_META, type Category } from '../../lib/projectMeta';

// Load every project, newest first.
const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Build the sections in the order defined in projectMeta.ts, each holding the
// projects whose category matches.
const sections = (Object.keys(CATEGORY_META) as Category[])
  .map((category) => ({
    category,
    meta: CATEGORY_META[category],
    items: projects.filter((p) => p.data.category === category),
  }))
  .sort((a, b) => a.meta.order - b.meta.order);
---

<BaseLayout
  title="Projects — [[YOUR_NAME]]"
  description="Software projects in three tiers: flagship original ideas, guided tutorial builds, and small tools that solve real problems."
>
  <h1 class="font-serif text-3xl font-bold text-slate-900 dark:text-white">Projects</h1>
  <p class="mt-2 text-slate-600 dark:text-slate-400">
    My build work, grouped by kind — from original, ambitious ideas to small
    tools that scratch a real itch.
  </p>

  {
    sections.map((section) => (
      <section class="mt-12">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 dark:text-white">
          {section.meta.title}
        </h2>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{section.meta.blurb}</p>

        {section.items.length === 0 ? (
          <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
            Nothing here yet — watch this space.
          </p>
        ) : (
          <div class="mt-5 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
            {section.items.map((project) => (
              <ProjectCard
                id={project.id}
                title={project.data.title}
                description={project.data.description}
                tags={project.data.tags}
                status={STATUS_META[project.data.status] ?? undefined}
              />
            ))}
          </div>
        )}
      </section>
    ))
  }
</BaseLayout>
