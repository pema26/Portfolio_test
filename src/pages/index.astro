---
// ============================================================================
//  src/pages/index.astro  —  the HOME page  (the "/" route)
// ============================================================================
//
//  Because of file-based routing, this file IS the home page. To add another
//  top-level page, copy an existing file in src/pages/ (e.g. about.astro).
//
//  WHAT'S HERE: a hero with your name + one-liner, a short intro, the
//  interactive canvas demo, a strip of "featured" projects, and a contact
//  call-to-action. Edit the marked spots to make it yours.
// ============================================================================

import BaseLayout from '../layouts/BaseLayout.astro';
import CanvasDemo from '../components/CanvasDemo.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

// Load all projects, keep only the ones marked `featured: true`, newest first.
const featured = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="[[YOUR_NAME]] — Developer & Researcher"
  description="London-based developer and researcher working across software engineering, low-level graphics, and molecular biology."
>
  <!-- ===================== HERO ===================== -->
  <!-- EDIT HERE: your name and one-line positioning statement. -->
  <section class="py-8 sm:py-12">
    <p class="mb-3 text-sm font-medium uppercase tracking-wider text-accent-500">
      London-based developer &amp; researcher
    </p>
    <h1 class="font-serif text-4xl font-bold leading-tight text-slate-900 sm:text-5xl dark:text-white">
      [[YOUR_NAME]]
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
      I build with <strong class="font-semibold text-slate-800 dark:text-slate-100">Python</strong>,
      <strong class="font-semibold text-slate-800 dark:text-slate-100">R</strong>, and
      low-level <strong class="font-semibold text-slate-800 dark:text-slate-100">graphics</strong>,
      with a research background in molecular biology. This site is where my
      coding projects and scientific work sit side by side.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="/projects"
        class="rounded-lg bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent-500"
      >
        View my work
      </a>
      <a
        href="/contact"
        class="rounded-lg border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-accent-400 hover:text-accent-500 dark:border-slate-700 dark:text-slate-200"
      >
        Get in touch
      </a>
    </div>
  </section>

  <!-- ===================== CANVAS DEMO ===================== -->
  <section class="py-8">
    <CanvasDemo />
  </section>

  <!-- ===================== FEATURED PROJECTS ===================== -->
  <section class="py-8">
    <div class="mb-6 flex items-baseline justify-between">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 dark:text-white">
        Featured work
      </h2>
      <a href="/projects" class="text-sm font-medium text-accent-500 hover:underline">
        All projects &rarr;
      </a>
    </div>

    {
      featured.length === 0 ? (
        <p class="text-slate-500 dark:text-slate-400">
          No featured projects yet. Set <code>featured: true</code> in a
          project's frontmatter to show it here.
        </p>
      ) : (
        <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
          {featured.map((project) => (
            <ProjectCard
              id={project.id}
              title={project.data.title}
              description={project.data.description}
              category={project.data.category}
              tags={project.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>

  <!-- ===================== CONTACT CTA ===================== -->
  <section class="my-8 rounded-2xl border border-slate-200 bg-slate-50 p-8 text-center dark:border-slate-800 dark:bg-slate-900">
    <h2 class="font-serif text-2xl font-semibold text-slate-900 dark:text-white">
      Let's talk
    </h2>
    <p class="mx-auto mt-2 max-w-md text-slate-600 dark:text-slate-400">
      Interested in my work or have an opportunity to share? I'd love to hear
      from you.
    </p>
    <a
      href="/contact"
      class="mt-5 inline-block rounded-lg bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-accent-500"
    >
      Contact me
    </a>
  </section>
</BaseLayout>
