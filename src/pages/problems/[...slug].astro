---
// ============================================================================
//  src/pages/problems/[...slug].astro  —  ONE solved problem's page
// ============================================================================
//
//  Same pattern as the project pages: this single file generates a page for
//  every challenge Markdown file automatically. The body's fenced code blocks
//  (```python / ```cpp) are syntax-highlighted by Astro for you. Edit the
//  Markdown to change a challenge; you don't edit this template.
// ============================================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const challenges = await getCollection('challenges');
  return challenges.map((challenge) => ({
    params: { slug: challenge.id },
    props: { challenge },
  }));
}

const { challenge } = Astro.props;
const { Content } = await render(challenge);

const dateLabel = challenge.data.date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout title={`${challenge.data.title} — [[YOUR_NAME]]`} description={challenge.data.description}>
  <a href="/problems" class="text-sm font-medium text-accent-500 hover:underline">
    &larr; All problems
  </a>

  <header class="mt-4">
    <div class="flex flex-wrap items-center gap-3">
      <span class="rounded-full bg-accent-100 px-2.5 py-0.5 text-xs font-medium text-accent-700 dark:bg-accent-900/50 dark:text-accent-300">
        {challenge.data.source}
      </span>
      {
        challenge.data.difficulty && (
          <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
            Rating {challenge.data.difficulty}
          </span>
        )
      }
      <time class="text-sm text-slate-500 dark:text-slate-400">{dateLabel}</time>
    </div>

    <h1 class="mt-3 font-serif text-3xl font-bold text-slate-900 dark:text-white">
      {challenge.data.title}
    </h1>
    <p class="mt-2 text-lg text-slate-600 dark:text-slate-300">
      {challenge.data.description}
    </p>

    <ul class="mt-4 flex flex-wrap gap-1.5">
      {
        challenge.data.tags.map((tag) => (
          <li class="rounded bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-400">
            {tag}
          </li>
        ))
      }
    </ul>

    {
      challenge.data.problemUrl && (
        <div class="mt-5">
          <a
            href={challenge.data.problemUrl}
            class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-accent-400 hover:text-accent-500 dark:border-slate-700 dark:text-slate-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            Original problem &rarr;
          </a>
        </div>
      )
    }
  </header>

  <article class="prose-content mt-8 text-slate-700 dark:text-slate-300">
    <Content />
  </article>
</BaseLayout>
