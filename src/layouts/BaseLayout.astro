---
// ============================================================================
//  BaseLayout.astro  —  the shared "frame" wrapped around every page
// ============================================================================
//
//  PURPOSE: every page on the site uses this layout, so the <head>, the header
//  navigation, the footer, and the dark-mode behaviour all live here in ONE
//  place. A page just provides its title, description, and its content.
//
//  HOW A PAGE USES IT (example):
//      ---
//      import BaseLayout from '../layouts/BaseLayout.astro';
//      ---
//      <BaseLayout title="About" description="A little about me.">
//        <h1>About</h1>
//        ...your content...
//      </BaseLayout>
// ============================================================================

import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Optional custom social-share image for this page. */
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} image={image} />

    <!-- ClientRouter enables Astro's built-in View Transitions: smooth
         fade/slide between pages with no heavy JavaScript framework. It
         automatically respects "prefers-reduced-motion". -->
    <ClientRouter />

    <!-- NO-FLASH THEME SCRIPT.
         This runs immediately, before the page is painted, so the correct
         theme is applied instantly and you never see a flash of the wrong
         colours.

         WHICH THEME WINS: a choice the visitor made with the toggle button
         (saved in localStorage) always wins; otherwise we follow the
         operating system / browser "dark mode" setting.

         IMPORTANT: it also re-applies the theme after every page navigation.
         The <ClientRouter /> above swaps in the new page's <html> attributes,
         which would otherwise wipe the "dark" class and dump you into light
         mode every time you click a nav link. Listening for Astro's
         "astro:after-swap" event (which fires right after the swap, before
         the new page is painted) puts the class back with no flash.

         `is:inline` tells Astro to leave this script exactly as-is in the
         <head>. You should not need to edit it. -->
    <script is:inline>
      (function () {
        const osPrefersDark = window.matchMedia('(prefers-color-scheme: dark)');

        function applyTheme() {
          const saved = localStorage.getItem('theme');
          // A saved manual choice wins; otherwise follow the OS setting.
          const dark = saved ? saved === 'dark' : osPrefersDark.matches;
          document.documentElement.classList.toggle('dark', dark);
        }

        applyTheme(); // first load
        document.addEventListener('astro:after-swap', applyTheme); // every navigation

        // If the OS switches theme (e.g. automatic dark mode at sunset) and
        // the visitor never picked one manually, follow along live.
        osPrefersDark.addEventListener('change', applyTheme);

        // Keep every open tab in sync: the "storage" event fires in OTHER
        // tabs whenever the toggle saves a new choice in this one.
        window.addEventListener('storage', (event) => {
          if (event.key === 'theme') applyTheme();
        });
      })();
    </script>
  </head>

  <body class="min-h-screen bg-white text-slate-800 antialiased dark:bg-slate-950 dark:text-slate-200">
    <!-- Skip link for keyboard / screen-reader users (accessibility). -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-accent-600 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <Header />

    <!-- The actual page content gets dropped in here via <slot />. -->
    <!-- Full-width content with a little breathing room at the edges. -->
    <main id="main" class="w-full px-4 py-10 sm:px-6 lg:px-10 animate-fade-in">
      <slot />
    </main>

    <Footer />
  </body>
</html>
